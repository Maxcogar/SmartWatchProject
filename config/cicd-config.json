{
  "cicd": {
    "version": "1.0.0",
    "project": {
      "name": "SmartWatch-ESP32S3",
      "target": "ESP32-S3",
      "framework": "ESP-IDF",
      "architecture": "layered"
    },
    
    "pipeline": {
      "stages": [
        {
          "name": "validation",
          "enabled": true,
          "scripts": [
            "scripts\\validate-documents.ps1"
          ],
          "timeout": "5m",
          "retry_count": 2
        },
        {
          "name": "build",
          "enabled": true,
          "scripts": [
            "firmware\\build_scripts\\build.ps1"
          ],
          "configurations": ["debug", "release", "test"],
          "timeout": "15m",
          "retry_count": 1
        },
        {
          "name": "test",
          "enabled": true,
          "scripts": [
            "cicd\\testing-pipeline.ps1"
          ],
          "types": ["unit", "integration", "hardware"],
          "timeout": "20m",
          "retry_count": 2
        },
        {
          "name": "quality",
          "enabled": true,
          "scripts": [
            "cicd\\quality-integration.ps1",
            "scripts\\quality-metrics-collector.ps1"
          ],
          "timeout": "10m",
          "retry_count": 1
        },
        {
          "name": "deploy",
          "enabled": true,
          "scripts": [
            "cicd\\deployment-automation.ps1"
          ],
          "environments": ["development", "staging", "production"],
          "timeout": "30m",
          "retry_count": 0
        },
        {
          "name": "monitor",
          "enabled": true,
          "scripts": [
            "cicd\\monitoring-dashboard.ps1"
          ],
          "timeout": "5m",
          "retry_count": 1
        }
      ],
      
      "quality_gates": {
        "build_success_required": true,
        "test_pass_threshold": 0.95,
        "coverage_threshold": 0.80,
        "quality_score_threshold": 85,
        "security_scan_required": true,
        "performance_regression_threshold": 0.10
      },
      
      "notifications": {
        "enabled": true,
        "channels": [
          {
            "type": "console",
            "level": "info",
            "enabled": true
          },
          {
            "type": "file",
            "path": "logs\\cicd-notifications.log",
            "level": "debug",
            "enabled": true
          },
          {
            "type": "webhook",
            "url": "",
            "level": "error",
            "enabled": false
          }
        ]
      }
    },
    
    "build": {
      "esp_idf": {
        "version": "5.1+",
        "target": "esp32s3",
        "optimization_levels": {
          "debug": "O0",
          "release": "O2",
          "test": "O1"
        },
        "memory_layouts": {
          "debug": "debug.ld",
          "release": "release.ld",
          "test": "test.ld"
        }
      },
      
      "configurations": {
        "debug": {
          "defines": ["DEBUG=1", "LOG_LEVEL=5"],
          "optimization": "O0",
          "debug_info": true,
          "assertions": true
        },
        "release": {
          "defines": ["RELEASE=1", "LOG_LEVEL=2"],
          "optimization": "O2",
          "debug_info": false,
          "assertions": false
        },
        "test": {
          "defines": ["TEST=1", "LOG_LEVEL=4", "UNIT_TESTS=1"],
          "optimization": "O1",
          "debug_info": true,
          "assertions": true
        }
      }
    },
    
    "testing": {
      "frameworks": {
        "unit": {
          "framework": "unity",
          "runner": "ceedling",
          "enabled": true,
          "timeout": "10m"
        },
        "integration": {
          "framework": "custom",
          "runner": "pytest",
          "enabled": true,
          "timeout": "15m"
        },
        "hardware": {
          "framework": "custom",
          "runner": "esp-idf-monitor",
          "enabled": true,
          "timeout": "20m",
          "devices": [
            {
              "name": "dev-board-1",
              "serial": "auto",
              "enabled": true
            }
          ]
        }
      },
      
      "coverage": {
        "enabled": true,
        "tool": "gcov",
        "threshold": 0.80,
        "exclude_patterns": [
          "**/test/**",
          "**/tests/**",
          "**/mock/**"
        ]
      },
      
      "performance": {
        "enabled": true,
        "benchmarks": {
          "boot_time": {
            "threshold": 3000,
            "unit": "ms"
          },
          "memory_usage": {
            "threshold": 80,
            "unit": "percent"
          },
          "battery_life": {
            "threshold": 72,
            "unit": "hours"
          }
        }
      }
    },
    
    "quality": {
      "integration": {
        "existing_scripts": {
          "validate_documents": "scripts\\validate-documents.ps1",
          "quality_metrics": "scripts\\quality-metrics-collector.ps1"
        },
        "thresholds": {
          "architecture_score": 85,
          "code_quality_score": 80,
          "documentation_score": 75,
          "security_score": 90
        }
      },
      
      "static_analysis": {
        "enabled": true,
        "tools": [
          {
            "name": "cppcheck",
            "enabled": true,
            "config": "config\\cppcheck.cfg"
          },
          {
            "name": "clang-tidy",
            "enabled": true,
            "config": ".clang-tidy"
          }
        ]
      },
      
      "security": {
        "enabled": true,
        "scans": [
          {
            "name": "dependency_check",
            "enabled": true
          },
          {
            "name": "static_security",
            "enabled": true
          }
        ]
      }
    },
    
    "deployment": {
      "environments": {
        "development": {
          "auto_deploy": true,
          "approval_required": false,
          "rollback_enabled": true,
          "ota_enabled": true,
          "signing_required": false
        },
        "staging": {
          "auto_deploy": false,
          "approval_required": true,
          "rollback_enabled": true,
          "ota_enabled": true,
          "signing_required": true
        },
        "production": {
          "auto_deploy": false,
          "approval_required": true,
          "rollback_enabled": true,
          "ota_enabled": true,
          "signing_required": true,
          "backup_required": true
        }
      },
      
      "ota": {
        "enabled": true,
        "server": {
          "host": "localhost",
          "port": 8080,
          "protocol": "https"
        },
        "signing": {
          "enabled": true,
          "key_path": "keys\\signing.key",
          "cert_path": "keys\\signing.crt"
        }
      },
      
      "rollback": {
        "enabled": true,
        "max_versions": 3,
        "auto_rollback_on_failure": true,
        "health_check_timeout": "5m"
      }
    },
    
    "monitoring": {
      "dashboard": {
        "enabled": true,
        "integration_with_existing": true,
        "existing_dashboard": "scripts\\quality-metrics-collector.ps1",
        "refresh_interval": "30s",
        "port": 8081
      },
      
      "metrics": {
        "build_metrics": {
          "enabled": true,
          "retention_days": 30
        },
        "test_metrics": {
          "enabled": true,
          "retention_days": 60
        },
        "deployment_metrics": {
          "enabled": true,
          "retention_days": 90
        },
        "quality_metrics": {
          "enabled": true,
          "retention_days": 365
        }
      },
      
      "alerts": {
        "enabled": true,
        "channels": [
          {
            "type": "console",
            "enabled": true
          },
          {
            "type": "file",
            "path": "logs\\alerts.log",
            "enabled": true
          }
        ],
        "rules": [
          {
            "name": "build_failure",
            "condition": "build.status == 'failed'",
            "severity": "high",
            "enabled": true
          },
          {
            "name": "test_failure_rate",
            "condition": "test.failure_rate > 0.05",
            "severity": "medium",
            "enabled": true
          },
          {
            "name": "deployment_failure",
            "condition": "deploy.status == 'failed'",
            "severity": "critical",
            "enabled": true
          }
        ]
      }
    },
    
    "paths": {
      "project_root": ".",
      "scripts": "scripts",
      "cicd": "cicd",
      "firmware": "firmware",
      "config": "config",
      "logs": "logs",
      "reports": "reports",
      "keys": "keys",
      "temp": "temp"
    },
    
    "logging": {
      "enabled": true,
      "level": "info",
      "file": "logs\\cicd.log",
      "max_size_mb": 100,
      "max_files": 10,
      "format": "[{timestamp}] [{level}] [{component}] {message}"
    }
  }
}